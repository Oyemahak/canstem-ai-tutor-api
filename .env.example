PORT=4000
NODE_ENV=development

# Comma-separated allowed origins (local frontend + later Vercel)
CORS_ORIGIN=http://localhost:3000

# Postgres (Render) or MySQL (Cloudways) — replace with real URL in .env / Render env vars
# Local dev (Mac -> Render external): add sslmode=require
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME?schema=public&sslmode=require

# Auth
JWT_SECRET=CHANGE_ME_SUPER_LONG_RANDOM_STRING
COOKIE_NAME=canstem_session

# OpenAI (leave empty until ready)
OPENAI_API_KEY=
OPENAI_TEXT_MODEL=gpt-5
OPENAI_REALTIME_MODEL=gpt-5-realtime-preview
OPENAI_REALTIME_VOICE=alloy